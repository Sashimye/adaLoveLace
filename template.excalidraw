      "versionNonce": 785766070,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780402808039,
      "link": null,
      "locked": false,
      "text": "Difficulté : Les informations liées aux\n projets sont dispersées entre les emails,\n les messages instantanés et les notes de réunion. \nLorsqu'un client demande où en est son projet, elle doit \ncontacter plusieurs \npersonnes pour obtenir une vision complète de l'avancement.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Difficulté : Les informations liées aux\n projets sont dispersées entre les emails,\n les messages instantanés et les notes de réunion. \nLorsqu'un client demande où en est son projet, elle doit \ncontacter plusieurs \npersonnes pour obtenir une vision complète de l'avancement.",
      "autoResize": true,
      "lineHeight": 1.25
    },
