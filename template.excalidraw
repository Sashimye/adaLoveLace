    },
    {
      "id": "pIPzwQASJooXWikQMwQBy",
      "type": "text",
      "x": -383.75000762939453,
      "y": 279.5833511352539,
      "width": 576.9995727539062,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
